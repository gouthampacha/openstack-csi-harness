#cloud-config
manage_etc_hosts: localhost
package_update: true
runcmd:
  - update-ca-certificates
  - curl -sfL https://get.k3s.io | INSTALL_K3S_VERSION={{ k3s_version }} INSTALL_K3S_EXEC="--disable traefik --disable metrics-server --disable servicelb --disable-cloud-controller --kubelet-arg=cloud-provider=external --write-kubeconfig-mode=644 --tls-san={{ k3s_vm_fip }}" sh -
  - |
    until [ -f /etc/rancher/k3s/k3s.yaml ]; do sleep 2; done
    kubectl --kubeconfig /etc/rancher/k3s/k3s.yaml taint nodes --all node.cloudprovider.kubernetes.io/uninitialized- || true
  - snap install helm --classic
write_files:
  - path: /usr/local/share/ca-certificates/registry-ca.crt
    content: |
{{ registry_ca_cert | indent(6, first=true) }}
  - path: /etc/rancher/k3s/registries.yaml
    content: |
      mirrors:
        "{{ devstack_ip_address }}:{{ registry_port }}":
          endpoint:
            - "https://{{ devstack_ip_address }}:{{ registry_port }}"
      configs:
        "{{ devstack_ip_address }}:{{ registry_port }}":
          tls:
            ca_file: "/usr/local/share/ca-certificates/registry-ca.crt"
