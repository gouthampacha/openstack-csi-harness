[[local|localrc]]
RECLONE=False
HOST_IP={{ local_ip_address }}
DEST=/opt/stack
DATA_DIR=${DEST}/data
LOGFILE=$DEST/logs/stack.sh.log
VERBOSE=True
LOG_COLOR=False
LOGDAYS=1
SERVICE_TIMEOUT=300

DATABASE_PASSWORD=password
ADMIN_PASSWORD=password
SERVICE_PASSWORD=password
SERVICE_TOKEN=password
RABBIT_PASSWORD=password

GIT_BASE=https://github.com
TARGET_BRANCH={{ devstack_branch }}

ENABLED_SERVICES=rabbit,mysql,key

# Host tuning
ENABLE_SYSCTL_MEM_TUNING=true
ENABLE_SYSCTL_NET_TUNING=true
ENABLE_ZSWAP=true

{% if "nova" in devstack_services %}
# Nova
enable_service n-api
enable_service n-cpu
enable_service n-cond
enable_service n-sch
enable_service n-api-meta

# Placement
enable_service placement-api
enable_service placement-client
{% endif %}

{% if "glance" in devstack_services %}
# Glance
enable_service g-api
enable_service g-reg
{% endif %}

{% if "cinder" in devstack_services %}
# Cinder
enable_service cinder
enable_service c-api
enable_service c-vol
enable_service c-sch
{% endif %}

{% if "neutron" in devstack_services %}
# Neutron
enable_plugin neutron ${GIT_BASE}/openstack/neutron.git {{ devstack_branch }}
enable_service q-svc
enable_service q-ovn-metadata-agent
enable_service q-trunk
enable_service q-qos
enable_service ovn-controller
enable_service ovn-northd
enable_service ovs-vswitchd
enable_service ovsdb-server

ML2_L3_PLUGIN="ovn-router,trunk,qos"
OVN_L3_CREATE_PUBLIC_NETWORK="True"
PUBLIC_BRIDGE_MTU="1430"

IP_VERSION=4
IPV4_ADDRS_SAFE_TO_USE=10.1.0.0/26
FIXED_RANGE=10.1.0.0/26
NETWORK_GATEWAY=10.1.0.1
FLOATING_RANGE=172.24.5.0/24
PUBLIC_NETWORK_GATEWAY=172.24.5.1
{% endif %}

{% if "manila" in devstack_services %}
# Manila
enable_plugin manila ${GIT_BASE}/openstack/manila {{ devstack_branch }}
MANILA_SERVICE_IMAGE_ENABLED=False
SHARE_DRIVER={{ manila_driver | default('manila.share.drivers.lvm.LVMShareDriver') }}
MANILA_DEFAULT_SHARE_TYPE_EXTRA_SPECS='snapshot_support=True create_share_from_snapshot_support=True revert_to_snapshot_support=True mount_snapshot_support=True'
MANILA_CONFIGURE_DEFAULT_TYPES=True

{% if manila_backends is defined %}
MANILA_ENABLED_BACKENDS={{ manila_backends | map(attribute='name') | join(',') }}
{% for backend in manila_backends %}
MANILA_BACKEND{{ loop.index }}_CONFIG_GROUP_NAME={{ backend.name }}
MANILA_SHARE_BACKEND{{ loop.index }}_NAME={{ backend.name | upper }}
MANILA_OPTGROUP_{{ backend.name }}_driver_handles_share_servers={{ backend.driver_handles_share_servers | default(manila_dhss) | default(false) | ternary('True', 'False') }}
MANILA_OPTGROUP_{{ backend.name }}_lvm_share_export_ips={{ local_ip_address }}
{% endfor %}
{% endif %}

{% if share_backing_file_size is defined %}
SHARE_BACKING_FILE_SIZE={{ share_backing_file_size }}
{% endif %}

{% if manila_cephfs_backend is defined and manila_cephfs_backend == 'nfs' %}
# CephFS-NFS configuration
MANILA_CEPH_DRIVER_ENABLED_PROTOCOL=NFS
{% if manila_cephfs_nfs_ganesha | default(false) %}
MANILA_SETUP_NFS_GANESHA=True
{% endif %}
{% elif manila_cephfs_backend is defined and manila_cephfs_backend == 'native' %}
# Native CephFS configuration
MANILA_CEPH_DRIVER_ENABLED_PROTOCOL=CEPHFS
{% endif %}
{% endif %}

{% for plugin in devstack_plugins | default([]) %}
# Plugin: {{ plugin.name }}
enable_plugin {{ plugin.name }} {{ plugin.repo }} {{ devstack_branch }}
{% endfor %}

# Pre-install hook
[[local|pre-install]]
if [ -f /opt/stack/data/venv/bin/activate ]; then
    source /opt/stack/data/venv/bin/activate
    pip install --upgrade pip setuptools
    deactivate
fi

{% if "nova" in devstack_services %}
[[post-config|$NOVA_CONF]]
[libvirt]
device_detach_timeout = 1
{% endif %}

{% if "glance" in devstack_services %}
[[post-config|$GLANCE_API_CONF]]
[glance_store]
default_store = file
{% endif %}

{% if "neutron" in devstack_services %}
[[post-config|$NEUTRON_CONF]]
[DEFAULT]
global_physnet_mtu = 1430
{% endif %}

{% if cinder_driver is defined %}
[[post-config|$CINDER_CONF]]
[DEFAULT]
enabled_backends = ceph

[ceph]
volume_driver = {{ cinder_driver }}
volume_backend_name = ceph
rbd_pool = {{ cinder_rbd_pool | default('volumes') }}
rbd_ceph_conf = {{ cinder_rbd_ceph_conf | default('/etc/ceph/ceph.conf') }}
rbd_user = {{ cinder_rbd_user | default('cinder') }}
rbd_flatten_volume_from_snapshot = false
rbd_max_clone_depth = 5
{% endif %}
